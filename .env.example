# ==============================
# Application
# ==============================
PROJECT_NAME="Bot Server"
API_V1_STR="/api/v1"
ENVIRONMENT="development"  # development | production | staging
PORT=3041
HOST="0.0.0.0"
DOMAIN_URL="http://localhost:3041"
FRONTEND_URL="http://localhost:3000"
SHOW_DOCS=true

# ==============================
# Logging
# ==============================
LOG_LEVEL="INFO"
LOG_FILE="logs/app.log"
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=7

# ==============================
# MongoDB
# ==============================
# DATABASE_URI được map vào MONGODB_URL trong code
DATABASE_URI="mongodb://localhost:27017"
DATABASE_NAME="your_database_name"
MIN_POOL_SIZE=10
MAX_POOL_SIZE=100
MONGODB_MAX_RETRIES=5
MONGODB_RETRY_DELAY=2

# ==============================
# Redis
# ==============================
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_PASSWORD=""
REDIS_DB=0

# ==============================
# Security
# ==============================
# JWT_SECRET được map vào SECRET_KEY trong code
JWT_SECRET="your-secret-key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=60
SALT_ROUNDS=10
HASH_PEPPER="pepper"

# ==============================
# AI API Keys
# ==============================
GGG_AI_API_KEY="your-google-gemini-key"
OPENAI_API_KEY="your-openai-key"
JINA_API_KEY="your-jina-key"
COHERE_API_KEY="your-cohere-key"

# Cấu hình riêng cho Gemini trong Bot-Server
GEMINI_MODEL="gemini-1.5-flash"
GEMINI_TIMEOUT=30
GEMINI_MAX_HISTORY=20

# ==============================
# Social Media Integration
# ==============================
# Facebook
FACEBOOK_APP_ID=""
FACEBOOK_REDIRECT_URI=""
FACEBOOK_APP_SECRET=""
FACEBOOK_WEBHOOK_VERIFY_TOKEN=""

# Zalo
ZALO_APP_ID=""
ZALO_REDIRECT_URI=""
ZALO_APP_SECRET=""

# Telegram
TELEGRAM_WEBHOOK_SECRET_TOKEN=""

# ==============================
# Third Party Services
# ==============================
# Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# SendGrid
SENDGRID_SENDER=""
SENDGRID_API_KEY=""

# Svix
SVIX_API_KEY=""
SVIX_SERVER_URL=""

# Notion
NOTION_CLIENT_ID=""
NOTION_CLIENT_SECRET=""
# CORS`nBACKEND_CORS_ORIGINS=\"http://localhost:5173,http://localhost:3000\"
BACKEND_CORS_ORIGINS=\"http://localhost:5173,http://localhost:3000\"
